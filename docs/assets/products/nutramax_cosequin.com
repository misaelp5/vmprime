    <script>
      $(function () {
        let emptest_frame_left = document.querySelector(
          ".emptest-frame-container.inactive.left.w-inline-block"
        );
        let emptest_frame_right = document.querySelector(
          ".emptest-frame-container.inactive.right.w-inline-block"
        );
        if (emptest_frame_left != null) {
          $(".emptest-frame-container.inactive.left.w-inline-block").click(
            function (e) {
              e.preventDefault();
              $(".arrow-column.ondark.w-slider-arrow-left").trigger("tap");
            }
          );
        }
        if (emptest_frame_right != null) {
          $(".emptest-frame-container.inactive.right.w-inline-block").click(
            function (e) {
              e.preventDefault();
              $(".arrow-column.ondark.w-slider-arrow-right").trigger("tap");
            }
          );
        }
        /*
      setTimeout(function () {
      }, 5000);
      console.log("Is Good?");
      */
        jQuery(".arrow-column-herobanner.right.w-slider-arrow-right").keyup(
          function (event) {
            if (event.keyCode === 13) {
              jQuery(".rotator-arrow.w-icon-slider-right").click();
            }
          }
        );
        jQuery(".arrow-column-herobanner.w-slider-arrow-left").keyup(function (
          event
        ) {
          if (event.keyCode === 13) {
            jQuery(".rotator-arrow.w-icon-slider-left").click();
          }
        });
      });
    </script>
