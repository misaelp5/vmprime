phy-star-solid.svg\",576,\"trophy_star_solid_567be0706a\",1.3,\"/uploads/trophy_star_solid_567be0706a.svg\",\"2024-12-03T08:57:30.397Z\",{\"_13\":421,\"_295\":422,\"_242\":423,\"_217\":424,\"_298\":-5,\"_287\":-5,\"_301\":425},4,\"FurHaven Gift Cards\",\"Easy Gifting!\",\"products/furhaven-pet-products-gift-card\",{\"_303\":426},{\"_13\":427,\"_208\":428},67,{\"_15\":429,\"_308\":-5,\"_309\":-5,\"_310\":415,\"_312\":383,\"_314\":-5,\"_319\":430,\"_321\":385,\"_323\":386,\"_328\":431,\"_21\":432,\"_363\":-5,\"_364\":365,\"_366\":-5,\"_211\":433,\"_213\":433},\"gift-card-solid.svg\",\"gift_card_solid_3cede25dfb\",0.97,\"/uploads/gift_card_solid_3cede25dfb.svg\",\"2024-12-03T08:57:41.154Z\",{\"_13\":207,\"_285\":435,\"_295\":436,\"_437\":438,\"_287\":439,\"_298\":440},\"blocks.products-collection\",\"Featured Products\",\"collectionName\",\"fh-all-beds\",\"page-container home-products\",{\"_13\":207,\"_217\":441,\"_298\":442},\"/collections/fh-all-beds\",\"View all\",{\"_13\":207,\"_285\":444,\"_295\":445,\"_287\":446,\"_372\":447},\"blocks.slider\",\"What People Are Saying\",\"page-container home-reviews\",[448,453,458,463,468,473],{\"_13\":449,\"_295\":450,\"_242\":451,\"_217\":-5,\"_298\":-5,\"_287\":-5,\"_301\":452},75,\"Your pet will love this!\",\"\\\"Bought the jumbo size. Golden Retriever’s love it! So impressed, we bought 2 more!! Covers zip off for easy cleaning.\\\" \\n-Robert M.\",{\"_303\":-5},{\"_13\":454,\"_295\":455,\"_242\":456,\"_217\":-5,\"_298\":-5,\"_287\":-5,\"_301\":457},76,\"Never look back!\",\"\\\"The only beds my pups sleep on is Furheaven. They love this one and the Goliath and as always the biggest one offered! Just the best!!!\\\" \\n-Rawleigh M.\",{\"_303\":-5},{\"_13\":459,\"_295\":460,\"_242\":461,\"_217\":-5,\"_298\":-5,\"_287\":-5,\"_301\":462},77,\"Great Quality Dog Bed\",\"\\\"The taupe one is soft, thick, and everything I was looking for. She is a bichon/poodle mix. The medium is perfect for her.\\\" \\n-Carly E.\",{\"_303\":-5},{\"_13\":464,\"_295\":465,\"_242\":466,\"_217\":-5,\"_298\":-5,\"_287\":-5,\"_301\":467},78,\"Love, Love, Love\",\"\\\"Love the new cover, and the customer service at FurHaven was a dream come true. I am so impressed. They responded to my inquiry and took great care of me. I feel seen and appreciated for my purchase. THANK YOU!\\\"\\n-Summer M.\",{\"_303\":-5},{\"_13\":469,\"_295\":470,\"_242\":471,\"_217\":-5,\"_298\":-5,\"_287\":-5,\"_301\":472},79,\"outstanding quality, materials and workmanship\",\"\\\"outstanding quality, materials and workmanship at an affordable price. I even bought another cover for when this one needs to be cleaned.\\\"\\n-Scott B.\",{\"_303\":-5},{\"_13\":474,\"_295\":475,\"_242\":476,\"_217\":-5,\"_298\":-5,\"_287\":-5,\"_301\":477},80,\"A-MAZING!!\",\"\\\"This Bed is A-MAZING!! It is soooo comfortable and our dog absolutely LOVES it!! (I even climb in to cuddle with him - it is addicting!). The bolster sides are sturdy and supports his head and back - we could not be happier!! TAZ says Thank You, too!! \u003c3\\\"\\n-Cindi S.\",{\"_303\":-5},{\"_13\":207,\"_285\":479,\"_295\":-5,\"_287\":480,\"_242\":-5,\"_289\":290,\"_372\":481},\"blocks.grid\",\"page-container featured-categories\",[482,529,560,604,641],{\"_13\":230,\"_295\":71,\"_242\":483,\"_217\":484,\"_298\":485,\"_287\":-5,\"_301\":486},\"Cats and dogs alike love the bolsters' supportive feel\",\"/collections/fh-sofa-style-beds\",\"Shop now\",{\"_303\":487},{\"_13\":488,\"_208\":489},16,{\"_15\":490,\"_308\":-5,\"_309\":-5,\"_310\":491,\"_312\":492,\"_314\":493,\"_319\":524,\"_321\":497,\"_323\":498,\"_328\":525,\"_21\":526,\"_363\":-5,\"_364\":365,\"_366\":-5,\"_211\":527,\"_213\":528},\"55336087_SofaBed_Suede_FullSupport_MD_Gray_Lifestyle\",1333,672,{\"_316\":494,\"_333\":503,\"_342\":510,\"_351\":517},{\"_15\":495,\"_319\":496,\"_321\":497,\"_323\":498,\"_325\":-5,\"_310\":326,\"_312\":499,\"_328\":500,\"_330\":501,\"_21\":502},\"thumbnail_55336087_SofaBed_Suede_FullSupport_MD_Gr