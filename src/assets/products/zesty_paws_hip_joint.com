  @media screen and (min-width: 1200px) {
    .footer__cross-border {
      margin-inline-end: 50px;
    }
  }

  .social-media {
    flex-wrap: wrap;
    display: flex;
    gap: 10px;
  }

  .social-media__item {
    position: relative;
    transform: translateZ(0);
    box-shadow: none;
  }

  .social-media__item:before {
    display: none;
  }

  .social-media__link {
    color: currentColor;
    z-index: 1;
    justify-content: center;
    align-items: center;
    transition: all 0.3s cubic-bezier(0.215, 0.61, 0.355, 1);
    display: flex;
    position: relative;
    width: 50px;
    height: 50px;
    background: #f3f3f3;
    border-radius: 100px;
  }

  @media screen and (pointer: fine) {
    .social-media__item:hover .social-media__link {
      color: var(--white);
      background: var(--orange);
    }
  }

  /* custom css styles */
  .footer .go-to-top {
    border-radius: 100px;
    background: #29387e;
    width: 86px;
    height: 38px;
    color: var(--white);
    position: absolute;
    align-items: center;
    display: flex;
    gap: 10px;
    justify-content: center;
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    top: -120px;
    right: 40px;
    transition: all 0.3s ease-in-out;
  }

  @media (max-width: 740px) {
    .footer .go-to-top {
      top: -83px;
      right: 15px
