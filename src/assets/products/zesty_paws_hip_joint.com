</div><div id="shopify-section-sections--18706569068678__zesty_footer_Nxjbd7" class="shopify-section shopify-section-group-footer-group shopify-section--footer"><style>
  #shopify-section-sections--18706569068678__zesty_footer_Nxjbd7 .footer {
