    --border-color: 228, 229, 229;

    --footer-font-family: var(--heading-font-family);
  }

  /* styles.css */
  .footer {
    padding: 32px 0;
  }

  .footer > .container {
    position: relative;
  }

  .footer > .container::before {
    content: "";
    display: block;
    position: absolute;
    top: -32px;
    width: calc(100% - 30px);
    height: 2px;
    background: var(--blue);
    border-radius: 3px;
    left: 15px;
  }

  .footer__item {
    max-width: none;
  }

  .footer__item .linklist__item a {
    font-size: 15px;
    font-weight: 300;
    line-height: normal;
    padding: 1.5px 0;
  }

  .footer__item-contact {
    display: flex;
    gap: 13px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .footer__item.footer__item--social-media,
  .footer__item.footer__item--links {
    margin-block-start: 25px;
  }

  .footer__item-contact a {
    padding: 10px 20px;
    background: #f3f3f3;
    border-radius: 100px;
    font-size: 16px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
    font-family: var(--footer-font-family);
    transition: all 0.3s cubic-bezier(0.215, 0.61, 0.355, 1);
  }

  .footer__item-contact a:hover {
    background: var(--orange);
    color: rgb(var(--background));
  }

  .footer__item .linklist__item {
    line-height: normal;
    font-size: 15px;
  }

  .footer__item .linklist {
    display: grid;
  }

  .footer__item-title {
    text-transform: none;
    letter-spacing: 0;
    font-weight: 600;
    font-size: 16px;
    margin-block-end: 8px;
  }

  .footer__item .footer__item-title {
    font-family: var(--footer-font-family);
    font-weight: var(--heading-font-weight);
  }

  .footer__item--text .footer__item-title {
    font-family: var(--footer-font-family);
    font-size: 50px;
    font-weight: var(--heading-font-weight);
    line-height: 60px;
    text-wrap: nowrap;
    text-transform: none;
  }

  .footer__item--text p {
    font-size: 16px;
    font-weight: 600;
    line-height: 24px;
    font-family: var(--footer-font-family);
  }

  .footer__item--text {
    display: flex;
    gap: 55px;
  }

  .footer__item--social-media .footer__item-content {
    margin-block-start: 5px;
  }

  .footer__aside {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-block-start: 42px;
    gap: 15px;
  }

  .footer__cross-border {
    display: flex;
  }

  .footer__cross-border .popover-container + .popover-container {
    margin-inline-start: -1px;
  }

  .footer__newsletter-form {
    margin-block-start: 16px;
  }

  .footer__copyright,
  .footer__payment-methods {
    color: var(--grey-dark);
    display: block;
  }

  .footer__copyright {
    align-items: center;
    display: flex;
  }

  .footer__follow-and-payment {
    gap: 16px;
    margin-inline-start: auto;
    display: grid;
  }

  .footer__payment-methods-label {
    margin-block-end: 8px;
    display: inline-block;
  }

  .footer__privacy .linklist {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .footer__privacy .linklist__item {
    padding: 0 !important;
    font-size: 12px;
    line-height: normal;
    font-weight: 400;
  }

  @media (max-width: 740px) {
    .footer__item--text .footer__item-title {
      text-wrap: unset;
      font-size: 32px;
      line-height: normal;
      margin: 3px;
    }

    .footer__item--text {
      grid-column: span 2;
      text-align: center;
      justify-content: center;
    }

    .footer__item-contact a {
      font-size: 13px;
    }

    .footer__item-contact {
      justify-content: center;
      margin-top: 14px;
    }

    .footer__item.footer__item--social-media,
    .footer__item.footer__item--links {
      margin-block-start: 0;
    }

    .footer__inner {
