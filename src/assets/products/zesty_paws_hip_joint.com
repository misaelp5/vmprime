      column-gap: 30px;
      margin-block-start: 50px;
      display: flex;
      margin-top: 110px;
    }

    .footer__cross-border {
      margin-inline-end: 32px;
    }

    .footer__payment-methods,
    .footer__copyright {
      margin-block-start: 0;
    }

