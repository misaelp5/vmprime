<section class="section ">
  <div ><image-with-text reveal-on-scroll class="image-with-text  image-with-text--reverse image-with-text--overlap-text" style="--image-aspect-ratio: 1.0; --image-max-height: 972px">
      <div class="container">
        <div class="image-with-text__wrapper"><div class="image-with-text__image-wrapper"><img src="//zestypaws.com/cdn/shop/files/Zesty-Paws-Quiz.png?v=1773960932&amp;width=972" alt="" srcset="//zestypaws.com/cdn/shop/files/Zesty-Paws-Quiz.png?v=1773960932&amp;width=600 600w, //zestypaws.com/cdn/shop/files/Zesty-Paws-Quiz.png?v=1773960932&amp;width=700 700w, //zestypaws.com/cdn/shop/files/Zesty-Paws-Quiz.png?v=1773960932&amp;width=800 800w" width="972" height="972" loading="lazy" id="block-item_iTW7Dw-29312680427654" sizes="(max-width: 740px) calc(100vw - 96px), (max-width: 999px) calc(100vw - 160px), 600px" reveal-visibility="true" class="image-with-text__image"></div>

          <div class="image-with-text__content-wrapper">
            <div class="image-with-text__content-list"><image-with-text-item   class="image-with-text__content text-container text--left" ><h3 class="heading heading--large">
                      <split-lines reveal>Need help finding the right products?</split-lines>
