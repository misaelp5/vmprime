    <div class="hero-banner">
<div class="hero-banner__image-container">
<img src="/uploads/treat_dispensing_toy_pig_ls_dog_chewing_bed_buddy_03_rev2.jpg" class="hero-banner__image" srcset="/uploads/treat_dispensing_toy_pig_ls_dog_chewing_bed_buddy_03_rev2.jpg 1390w, 



/uploads/_hu34ebf2207ef940aacaf6bbf86de64c4b_560552_8f6dd851229dfe4bb3fe5e4f6cf4c269.jpg_  375w" title="Discover Premier Pet Products" />
</div>
<div class="hero-banner__content hero-banner__content--w-50 hero-banner__content--lc">
<div class="hero-header h1" style="color:#ffffff;text-shadow: 2px 2px #888888;">
<p>Discover<br /></p>
<p><span class="no-break no-break-resp">Premier Pet</span><sup>®</sup> Products</p>
</div>
<div class="hero-header--body font-size--large" style="color:#ffffff;text-shadow: 2px 2px #888888;">
<p>Making life with your pet <br />simple &amp; affordable.</p>
</div>
<div class="t-spacing--small">
<p><a href="/products" class="btn btn--secondary">Browse Products</a></p>
</div>
</div>
</div>
<div class="container text-align--center">
<div class="col-4 t-spacing--large" style="display: flex;flex-direction: column;">
<img src="uploads/pp_containment-bark-training_400x255_web_2022.jpg" alt="Graphic displaying how how in-ground fence system keeps dog in yard" class="width--full">
<div class="flex-grow--1 t-spacing--small">Give your dog the freedom to play & yourself peace of mind.</div>
<div class="t-spacing--small">
<p><a href="/containment" class="btn btn--primary">Browse Pet Fencing</a></p>
</div>
</div>
<div class="col-4 flex-grow--1 t-spacing--large" style="display: flex;flex-direction: column;">
<img src="uploads/pp_60oz_fountain_ls_400x255_web_2022v2.jpg" alt="Cat with fountain" class="width--full">
<div class="flex-grow--1 t-spacing--small">Provide your pet with fresh, filtered water & promote hydration.</div>
<div class="t-spacing--small">
<p><a href="/pet-fountains/" class="btn btn--primary">Browse Pet Fountains</a></p>
</div>
</div>
<div class="col-4 t-spacing--large" style="display: flex;flex-direction: column;">
<img src="uploads/bark_collar_ls_dog_window_winston_01_400x255_web_2022.jpg" alt="dog wearing bark control collar" class="width--full">
<div class="flex-grow--1 t-spacing--small">A safe & easy way to deter nuisance barking.</div>
<div class="t-spacing--small">
<p><a href="/bark-control" class="btn btn--primary">Browse Bark Collars</a></p>
</div>
</div>
</div>
    
    
        
<div class="video-player t-spacing--larger" data-videoplayer>
